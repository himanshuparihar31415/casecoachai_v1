# ─────────────────────────────────────────────────────────────
# Case Coach AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ─── Backend (Railway) ────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/casecoach

# JWT — generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_EXPIRES_IN=7d

# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# URL of the deployed frontend (used for CORS)
FRONTEND_URL=https://your-app.vercel.app

# URL of this backend
APP_URL=https://your-app.railway.app

# ─── Frontend (Vercel) ────────────────────────────────────────
# Set this as an environment variable in the Vercel dashboard
# It tells the React app where the backend API is
VITE_API_URL=https://your-app.railway.app
